{
  "name": "solana-react-dynamic",
  "displayName": "Solana React + Vite + Dynamic",
  "description": "React + Vite starter with Dynamic wallet authentication for Solana",
  "usecase": "Starter",
  "keywords": [
    "solana",
    "react",
    "vite",
    "dynamic",
    "dynamic-xyz",
    "wallet",
    "authentication",
    "typescript",
    "tailwind"
  ],
  "create-solana-dapp": {
    "instructions": [
      "Install dependencies:",
      "+{pm} install",
      "Copy .env.example to .env and add your Dynamic environment ID:",
      "+cp .env.example .env",
      "Get your Environment ID from https://app.dynamic.xyz/dashboard/developer",
      "Start the development server:",
      "+{pm} dev"
    ]
  },
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dynamic-labs/sdk-react-core": "4.76.0",
    "@dynamic-labs/solana": "4.76.0",
    "@solana/web3.js": "1.98.4",
    "@tailwindcss/vite": "4.1.18",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "20.19.21",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "15.15.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vite": "7.2.7"
  }
}
