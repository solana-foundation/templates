# X402 Configuration
# Copy this file to .env.local and fill in your values

# Your Solana wallet address that will receive payments
# This is where all payments will be sent
NEXT_PUBLIC_RECEIVER_ADDRESS=CmGgLQL36Y9ubtTsy2zmE46TAxwCBm66onZmPPhUWNqv

# Solana network to use
# Options (alias => CAIP-2):
# - solana-devnet => solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
# - solana-mainnet-beta => solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# Use devnet for testing with fake tokens; use mainnet-beta for production with real money.
NEXT_PUBLIC_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# Facilitator URL
# The service that verifies payments on the blockchain
# Default: https://x402.org/facilitator
NEXT_PUBLIC_FACILITATOR_URL=https://x402.org/facilitator

# Optional: Coinbase Developer Platform Client Key
# Only needed for facilitators that require a client key (for example, Coinbase).
# proxy.ts does not read this directly.
# Get this from: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_CDP_CLIENT_KEY=your_client_key_here
