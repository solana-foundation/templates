{
  "name": "privy-auth",
  "displayName": "Privy Auth",
  "description": "Authenticate users with Privy social logins and Solana embedded wallets",
  "usecase": "Auth",
  "keywords": [
    "privy",
    "authentication",
    "solana",
    "embedded-wallet",
    "social-login",
    "nextjs",
    "typescript"
  ],
  "create-solana-dapp": {
    "instructions": [
      "Set up Privy:",
      "1. Create an app at https://dashboard.privy.io",
      "2. Copy .env.example to .env.local and add your Privy App ID",
      "Start the app: +{pm} run dev"
    ]
  },
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.12.0",
    "@solana-program/memo": "^0.8.0",
    "@solana-program/system": "0.8.0",
    "@solana-program/token": "0.6.0",
    "@solana/kit": "3.0.3",
    "bs58": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "15.5.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.7",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
