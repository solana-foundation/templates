{
  "name": "staking-program",
  "displayName": "SPL Token Staking",
  "description": "Full-featured SPL token staking with Anchor smart contract and Next.js frontend",
  "usecase": "DeFi",
  "keywords": [
    "solana",
    "anchor",
    "staking",
    "spl-token",
    "nextjs",
    "defi",
    "typescript"
  ],
  "create-solana-dapp": {
    "instructions": [
      "Install Anchor program dependencies and build:",
      "+{pm} install",
      "+anchor build",
      "Install frontend dependencies:",
      "+cd app && {pm} install",
      "Start the development server:",
      "+cd app && {pm} dev"
    ]
  },
  "scripts": {
    "lint:fix": "prettier \"**/*.{js,ts}\" -w",
    "lint": "prettier \"**/*.{js,ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.2"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^5.7.3",
    "prettier": "^2.6.2"
  }
}
