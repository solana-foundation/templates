# Pay.sh CLI balance lookup for local sandbox tests.
#
# The CLI reads PAY_API_URL when selecting a funded stablecoin challenge.
# Pointing it at the Next.js app lets this template use the local balance
# shim at /v1/balance/stablecoins while Surfpool provides the actual sandbox
# SOL + USDC accounts. Use this only for local sandbox development.
PAY_API_URL=http://localhost:3000
