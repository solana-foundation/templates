{
  "name": "pay-sh-api-store",
  "displayName": "Pay.sh API Store",
  "description": "Next.js paid API storefront using Pay.sh sandbox gateways",
  "usecase": "Payments",
  "keywords": [
    "pay.sh",
    "pay",
    "http-402",
    "payments",
    "api",
    "nextjs",
    "tailwind",
    "typescript"
  ],
  "version": "0.1.0",
  "private": true,
  "create-solana-dapp": {
    "instructions": [
      "Install dependencies:",
      "+{pm} install",
      "Confirm the Pay.sh CLI is installed:",
      "pay --help",
      "Start the Next.js upstream API:",
      "+{pm} dev",
      "In another terminal, start the Pay.sh sandbox gateway:",
      "pay --sandbox server start pay-provider.yml --bind 127.0.0.1:1402 --debugger",
      "Call a paid endpoint through Pay.sh:",
      "PAY_API_URL=http://localhost:3000 pay --sandbox curl http://127.0.0.1:1402/api/insights"
    ],
    "rename": {
      "pay-sh-api-store": {
        "to": "{{name}}",
        "paths": [
          "package.json",
          "README.md"
        ]
      }
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
