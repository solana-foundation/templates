# --- Solana (the user-facing chain) ---
# Devnet only. The dWallet's ED25519 public key IS a Solana address; we airdrop,
# sign, and broadcast real transactions here.
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Sui (backstage: Ika runs on Sui) ---
# Ika is a Sui-based threshold-signature network. The "operator" Sui wallet pays
# the Ika fees (SUI for gas + IKA for the protocol). Testnet only.
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Ika network config selector. 'testnet' or 'mainnet'. Keep this 'testnet' —
# this template is a teaching tool and must never touch mainnet or real funds.
VITE_IKA_NETWORK=testnet
