{
  "name": "keychain-express",
  "displayName": "Keychain Express API",
  "description": "Express signing API using @solana/keychain — one signer interface, 13 pluggable key backends (memory, KMS, MPC, custodial)",
  "usecase": "Auth",
  "keywords": [
    "kit",
    "solana-kit",
    "keychain",
    "signers",
    "express",
    "kms",
    "mpc",
    "typescript"
  ],
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "ci": "npm run build && npm run lint && npm run format:check && npm run smoke",
    "dev": "tsx watch src/server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "smoke": "tsx src/smoke.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@solana/keychain": "^1.4.0",
    "@solana/kit": "^6.9.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@solana-program/memo": "^0.11.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "eslint": "^9",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0"
  }
}
