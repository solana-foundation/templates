# Port the signing API listens on
PORT=3000

# Which key backend to use. One of:
# memory, vault, aws-kms, gcp-kms, turnkey, privy, fireblocks, dfns, para, cdp, crossmint, openfort, utila
KEYCHAIN_BACKEND=memory

# --- memory (local development; no credentials needed) ---
# With neither variable set, an ephemeral keypair is generated on every restart.
# MEMORY_PRIVATE_KEY=            # base58 private key or U8Array string "[1, 2, ..., 64]"
# MEMORY_KEYPAIR_PATH=           # path to a Solana CLI keypair JSON file (e.g. ~/.config/solana/id.json)

# --- vault (HashiCorp Vault transit engine, ed25519 key) ---
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=
# VAULT_KEY_NAME=
# VAULT_PUBLIC_KEY=              # base58 Solana public key of the Vault transit key

# --- aws-kms (Ed25519 KMS key; credentials via the AWS default provider chain) ---
# AWS_KMS_KEY_ID=
# AWS_KMS_PUBLIC_KEY=            # base58 Solana public key of the KMS key
# AWS_REGION=us-east-1

# --- gcp-kms (EC_SIGN_ED25519 key; credentials via GCP application default credentials) ---
# GCP_KMS_KEY_NAME=projects/.../locations/.../keyRings/.../cryptoKeys/.../cryptoKeyVersions/1
# GCP_KMS_PUBLIC_KEY=            # base58 Solana public key of the KMS key

# --- turnkey ---
# TURNKEY_API_PRIVATE_KEY=       # hex-encoded P256 API private key
# TURNKEY_API_PUBLIC_KEY=        # hex-encoded P256 API public key
# TURNKEY_ORGANIZATION_ID=
# TURNKEY_PRIVATE_KEY_ID=
# TURNKEY_PUBLIC_KEY=            # base58 Solana public key of the Turnkey key

# --- privy ---
# PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# PRIVY_WALLET_ID=

# --- fireblocks ---
# FIREBLOCKS_API_KEY=
# FIREBLOCKS_PRIVATE_KEY_PEM=    # PEM string; literal \n escapes are normalized automatically
# FIREBLOCKS_VAULT_ACCOUNT_ID=

# --- dfns ---
# DFNS_AUTH_TOKEN=
# DFNS_CRED_ID=
# DFNS_PRIVATE_KEY_PEM=          # PEM string; literal \n escapes are normalized automatically
# DFNS_WALLET_ID=

# --- para (MPC) ---
# PARA_API_KEY=
# PARA_WALLET_ID=

# --- cdp (Coinbase Developer Platform) ---
# CDP_ADDRESS=                   # base58 Solana address of the CDP account
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# CDP_WALLET_SECRET=

# --- crossmint (message signing not supported by this backend) ---
# CROSSMINT_API_KEY=
# CROSSMINT_WALLET_LOCATOR=
# CROSSMINT_SIGNER=              # optional
# CROSSMINT_SIGNER_SECRET=       # optional

# --- openfort ---
# OPENFORT_ACCOUNT_ID=
# OPENFORT_SECRET_KEY=
# OPENFORT_WALLET_SECRET=

# --- utila (MPC) ---
# UTILA_NETWORK=
# UTILA_SERVICE_ACCOUNT_EMAIL=
# UTILA_SERVICE_ACCOUNT_PRIVATE_KEY_PEM=  # PEM string; literal \n escapes are normalized automatically
# UTILA_VAULT_ID=
# UTILA_WALLET_ID=
