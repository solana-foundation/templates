# Port for the Axum signing API (the Next.js rewrite in next.config.ts proxies /api/* here)
# BACKEND_PORT=8080

# Every backend whose variables are fully set appears in the signer registry
# (GET /api/signers) and can be selected per request. The memory backend is
# always available and needs no configuration.
#
# This template compiles the memory and vault backends. To add more (aws-kms,
# gcp-kms, turnkey, privy, fireblocks, dfns, para, cdp, crossmint, openfort,
# utila), enable the matching solana-keychain feature in Cargo.toml and add a
# constructor arm in src/signers.rs.

# --- memory (local development; no credentials needed) ---
# With neither variable set, an ephemeral keypair is generated on every restart.
# MEMORY_PRIVATE_KEY=            # base58 private key or U8Array string "[1, 2, ..., 64]"
# MEMORY_KEYPAIR_PATH=           # path to a Solana CLI keypair JSON file (e.g. ~/.config/solana/id.json)

# --- vault (HashiCorp Vault transit engine, ed25519 key) ---
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=
# VAULT_KEY_NAME=
# VAULT_PUBLIC_KEY=              # base58 Solana public key of the Vault transit key
# VAULT_ALLOW_HTTP=true          # DEV ONLY: allow a plain-HTTP local `vault server -dev`
