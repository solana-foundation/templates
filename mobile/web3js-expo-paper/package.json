{
  "name": "web3js-expo-paper",
  "displayName": "Paper Boilerplate",
  "description": "A template for building a Solana mobile app with Expo and React Native Paper.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "react-native-paper",
    "solana-web3js"
  ],
  "create-solana-dapp": {
    "instructions": [
      "To buld the Android app locally, run this:",
      "+{pm} run android"
    ],
    "versions:": {
      "adb": "33.0.0"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-snackbar"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run format:check && npm run android:build",
    "dev": "expo start",
    "doctor": "npx -y expo-doctor@latest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "reset-project": "node ./scripts/reset-project.js",
    "start": "expo start",
    "web": "expo start --web"
  },
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.85.5",
    "@wallet-ui/react-native-web3js": "^4.0.1",
    "deepmerge": "^4.3.1",
    "expo": "~55.0.8",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-web-browser": "~55.0.10",
    "js-base64": "^3.7.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.14.5",
    "react-native-quick-crypto": "^1.0.6",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.1",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "react-qr-code": "^2.0.16"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.33.0",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "private": true
}
